---
import { SERVICES } from '../lib/constants';
---

<section id="servicos" class="section-padding bg-dark-light">
  <div class="container-main">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Nossos Servicos</h2>
    <p class="text-white/60 text-center max-w-2xl mx-auto mb-12">{{SERVICES_SUBTITLE}}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {SERVICES.map((service) => (
        <div class="p-8 bg-dark rounded-2xl border border-white/10 hover:border-primary transition-all duration-300">
          <h3 class="text-xl font-bold mb-3">{service.name}</h3>
          <p class="text-white/60 text-sm">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
