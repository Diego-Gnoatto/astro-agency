---
import { FAQ } from '../lib/constants';
---

<section id="faq" class="section-padding">
  <div class="container-main max-w-3xl">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Perguntas Frequentes</h2>
    <div class="space-y-4">
      {FAQ.map((item) => (
        <details class="group p-6 bg-dark-light rounded-xl border border-white/10">
          <summary class="flex items-center justify-between cursor-pointer font-semibold">{item.question}<span class="text-primary group-open:rotate-45 transition-transform">+</span></summary>
          <p class="mt-4 text-white/70">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
