---
import { CONTACT } from '../lib/constants';
---

<section id="contato" class="section-padding bg-dark-light">
  <div class="container-main text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">{{CTA_HEADLINE}}</h2>
    <p class="text-white/60 max-w-2xl mx-auto mb-8">{{CTA_SUBHEADLINE}}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/orcamento/" class="btn-primary text-lg !px-10 !py-4">Solicite um Orcamento</a>
      <a href={`${CONTACT.whatsappLink}?text=${encodeURIComponent('Ola! Gostaria de saber mais.')}`} target="_blank" rel="noopener noreferrer" class="btn-secondary text-lg !px-10 !py-4">WhatsApp</a>
    </div>
  </div>
</section>
