---
import { PROCESS_STEPS } from '../lib/constants';
---

<section id="processo" class="section-padding">
  <div class="container-main">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Nosso Processo</h2>
    <p class="text-white/60 text-center max-w-2xl mx-auto mb-12">{{PROCESS_SUBTITLE}}</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {PROCESS_STEPS.map((step) => (
        <div class="text-center">
          <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4"><span class="text-2xl font-bold text-primary font-mono">{step.step}</span></div>
          <h3 class="text-lg font-bold mb-2">{step.title}</h3>
          <p class="text-white/60 text-sm">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
