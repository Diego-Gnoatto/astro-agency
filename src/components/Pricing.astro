  <div class="container-main">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Investimento</h2>
    <p class="text-white/60 text-center max-w-2xl mx-auto mb-12">{{PRICING_SUBTITLE}}</p>
    <div class="max-w-lg mx-auto p-8 bg-dark rounded-2xl border border-white/10 text-center">
      <p class="text-white/60 mb-4">{{PRICING_TEXT}}</p>
      <a href="/orcamento/" class="btn-primary">Solicite um Orcamento Personalizado</a>
    </div>
  </div>
</section>
